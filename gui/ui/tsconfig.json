{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": { "react": ["../../node_modules/preact/compat"], "react-dom": ["../../node_modules/preact/compat"] }
  },
  "include": ["src", "vite.config.ts"]
}
